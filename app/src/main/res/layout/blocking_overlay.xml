<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1E293B"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/blocked_platform_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Social Media Blocked"
        android:textColor="#F8FAFC"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="আমল ও আত্মনিয়ন্ত্রণের সময় সামাজিক যোগাযোগ মাধ্যম বন্ধ রাখা হয়েছে।\nFocus on your prayer and self-discipline."
        android:textColor="#94A3B8"
        android:textSize="14sp"
        android:gravity="center" />

    <Button
        android:id="@+id/btn_back_home"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:backgroundTint="#059669"
        android:text="Go to Home Screen"
        android:textColor="#FFFFFF" />
</LinearLayout>
